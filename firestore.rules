rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Carga el doc del usuario autenticado UNA vez — Firestore cachea el get() dentro del request.
    // IMPORTANTE: esta función NO debe usarse en la regla de /usuarios/{userId} para evitar
    // recursión circular (la regla de usuarios llamaría a isSuperAdmin que llama get(usuarios) de nuevo).
    function usuarioDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && usuarioDoc().system_role == 'super_admin';
    }

    // Devuelve true mientras el sistema no ha sido inicializado (config/setup no existe o initialized != true).
    // Permite el bootstrap del primer super_admin sin que exista todavía un usuario en Firestore.
    function sistemaNoInicializado() {
      let setupDoc = get(/databases/$(database)/documents/config/setup);
      return !setupDoc.exists || setupDoc.data.initialized != true;
    }

    // El usuario tiene un grant activo sobre la empresa dada.
    // Lee el campo denormalizado company_ids del doc de usuario (actualizado al crear/revocar grant).
    function tieneAccesoEmpresa(companyId) {
      return isSignedIn() &&
        companyId in usuarioDoc().get('company_ids', []);
    }

    // El usuario pertenece al mismo cliente que el doc (aislamiento de tenant a nivel cliente).
    function mismoCliente(docClienteId) {
      return isSignedIn() && usuarioDoc().cliente_id == docClienteId;
    }

    // El contacto pertenece al propio usuario autenticado (lo lee al iniciar sesión).
    function esMiContacto(contactoId) {
      return isSignedIn() && usuarioDoc().contact_id == contactoId;
    }

    // ── config ───────────────────────────────────────────────────────────────
    // Marcador público de estado del sistema (config/setup → { initialized }).
    // Lectura pública: la pantalla de login lo consulta SIN autenticar para saber
    // si debe mostrar el registro del primer super_admin. Solo expone un booleano.
    // Bootstrap: el primer super_admin puede marcar el sistema como inicializado
    // incluso antes de que su doc exista como super_admin validado (el doc de usuario
    // ya fue creado en el paso anterior del flujo de registro).
    match /config/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && sistemaNoInicializado());
    }

    // ── grants ───────────────────────────────────────────────────────────────
    // Solo super_admin puede crear/editar grants.
    // El usuario puede leer sus propios grants (para que el grantStore pueda cargarlos al login).
    match /grants/{grantId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create, update, delete: if isSuperAdmin();
    }

    // ── clientes ─────────────────────────────────────────────────────────────
    // Solo super_admin puede escribir. Lectura: super_admin o mismo cliente.
    // Fase 6 añadirá: owner del cliente también puede leer el suyo.
    match /clientes/{clienteId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && mismoCliente(clienteId));
      allow write: if isSuperAdmin();
    }

    // ── empresas ─────────────────────────────────────────────────────────────
    match /empresas/{empresaId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && (
          tieneAccesoEmpresa(empresaId) ||
          mismoCliente(resource.data.cliente_id)
        ));
      allow write: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(empresaId));
    }

    // ── usuarios ─────────────────────────────────────────────────────────────
    // La regla para el doc PROPIO NO usa isSuperAdmin() para evitar recursión circular:
    //   isSuperAdmin() → get(/usuarios/uid) → evalúa regla de usuarios → isSuperAdmin() → ...
    // Firestore cachea el get() dentro del request, pero la evaluación recursiva de reglas
    // dispara el error antes de que el caché ayude.
    //
    // Solución: separar en dos reglas.
    // 1. El propio usuario siempre puede leer/escribir su doc (rompe la recursión).
    // 2. Otros docs: se permite si quien accede es super_admin (usa isSuperAdmin() de forma segura
    //    porque el get(/usuarios/uid) ya fue resuelto sin recursión en el paso anterior).
    // 3. Bootstrap: si el sistema no está inicializado, se permite crear el primer usuario
    //    con uid == userId (solo escritura del propio doc durante el setup inicial).
    match /usuarios/{userId} {
      // Bootstrap del primer super_admin — solo si el sistema no ha sido inicializado.
      allow create: if isSignedIn() && request.auth.uid == userId && sistemaNoInicializado();
      // El usuario accede a su propio doc — sin get() adicional, rompe la recursión.
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      // Un super_admin puede leer/escribir cualquier doc de usuario.
      // Esta rama solo se evalúa cuando uid != userId, por lo que el get(usuarios/uid)
      // apunta a un doc distinto al que se está accediendo — sin recursión.
      allow read, write: if request.auth.uid != userId && isSuperAdmin();
    }

    // ── sesiones ─────────────────────────────────────────────────────────────
    match /sesiones/{sesionId} {
      allow read, write: if isSignedIn() &&
        (isSuperAdmin() ||
          resource == null ||
          resource.data.user_id == request.auth.uid);
    }

    // ── contactos ─────────────────────────────────────────────────────────────
    // Aislamiento por cliente_id. Los contactos no tienen company_id propio
    // (un contacto puede ser empleado en varias empresas del mismo cliente).
    // Bootstrap: si el sistema no está inicializado, se permite crear el primer contacto
    // (el del super_admin) sin que exista aún un usuario en Firestore.
    match /contactos/{contactoId} {
      allow create: if isSignedIn() && sistemaNoInicializado();
      allow read: if isSuperAdmin() ||
        esMiContacto(contactoId) ||
        (isSignedIn() && mismoCliente(resource.data.get('cliente_id', null)));
      allow write: if isSuperAdmin() ||
        (isSignedIn() && mismoCliente(resource.data.get('cliente_id', null)));
    }

    // ── empleados ─────────────────────────────────────────────────────────────
    match /empleados/{empleadoId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.company_id));
      allow write: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.company_id));
    }

    // ── ubicaciones ───────────────────────────────────────────────────────────
    match /ubicaciones/{ubicacionId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.company_id));
      allow write: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.company_id));
    }

    // ── zonas ─────────────────────────────────────────────────────────────────
    match /zonas/{zonaId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
      allow write: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
    }

    // ── estaciones ────────────────────────────────────────────────────────────
    match /estaciones/{estacionId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
      allow write: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
    }

    // ── habilidades ───────────────────────────────────────────────────────────
    // Temporal: catálogo global sin aislamiento. Fase 3 lo vinculará a empresa.
    match /habilidades/{habilidadId} {
      allow read, write: if isSignedIn();
    }

    // ── asignaciones ──────────────────────────────────────────────────────────
    // Nuevo schema: empresa_id, ubicacion_id, empleado_id, date, estacion_id,
    //   start, end, status ('sugerido'|'publicado'), active, deletedAt.
    // Lectura: cualquier usuario con acceso a la empresa (empleados ven su calendario).
    // Escritura general: acceso a la empresa.
    // Regla D5: si el doc existente tiene status='publicado', solo super_admin
    //   puede modificarlo (la CF generarAsignaciones usa Admin SDK → bypass).
    match /asignaciones/{asignacionId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
      allow create: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(request.resource.data.empresa_id));
      allow update, delete: if isSuperAdmin() ||
        (isSignedIn() &&
          tieneAccesoEmpresa(resource.data.empresa_id) &&
          resource.data.status != 'publicado');
    }

    // ── excepciones ───────────────────────────────────────────────────────────
    match /excepciones/{excepcionId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
      allow write: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
    }

    // ── reglas_asignacion ─────────────────────────────────────────────────────
    match /reglas_asignacion/{reglaId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
      allow write: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
    }

    // ── solicitudes ───────────────────────────────────────────────────────────
    match /solicitudes/{solicitudId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
      allow write: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
    }

    // ── documentos_tributarios ────────────────────────────────────────────────
    // Solo super_admin puede escribir (los webhooks usan Firebase Admin SDK que bypass las rules).
    // El owner del cliente puede leer los DTE de sus empresas.
    match /documentos_tributarios/{dteId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && tieneAccesoEmpresa(resource.data.empresa_id));
      allow write: if isSuperAdmin();
    }

    // ── Denegación por defecto ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
